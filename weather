<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>India Weather Pro-Dash</title>
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            --glass: rgba(255, 255, 255, 0.1);
            --glass-hover: rgba(255, 255, 255, 0.2);
            --accent: #00d2ff;
        }

        body {
            font-family: 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-gradient);
            height: 100vh;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
        }

        .dashboard {
            display: flex;
            width: 850px;
            height: 500px;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        }

        /* Left Sidebar - City List */
        .sidebar {
            width: 35%;
            background: rgba(0, 0, 0, 0.2);
            padding: 20px;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }

        .sidebar h3 {
            font-weight: 300;
            letter-spacing: 1px;
            margin-bottom: 25px;
            opacity: 0.8;
            padding-left: 10px;
        }

        .city-item {
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 15px;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255, 255, 255, 0.05);
        }

        .city-item:hover {
            background: var(--glass-hover);
            transform: translateX(5px);
        }

        .city-item.active {
            background: var(--accent);
            color: #1e3c72;
            font-weight: bold;
        }

        /* Right Panel - Info Display */
        .main-display {
            width: 65%;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
        }

        .main-display::before {
            content: '☁';
            position: absolute;
            top: 20px;
            right: 40px;
            font-size: 8rem;
            opacity: 0.1;
        }

        #city-title { font-size: 2.5rem; margin: 0; }
        #state-sub { opacity: 0.7; margin-bottom: 30px; }

        .temp-box {
            display: flex;
            align-items: baseline;
            gap: 10px;
        }

        #main-temp { font-size: 6rem; font-weight: 800; margin: 0; }
        .deg-symbol { font-size: 2rem; font-weight: 300; }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: auto;
        }

        .stat-card {
            background: rgba(0,0,0,0.2);
            padding: 15px;
            border-radius: 18px;
            text-align: center;
        }

        .stat-card label {
            display: block;
            font-size: 0.7rem;
            text-transform: uppercase;
            opacity: 0.6;
            margin-bottom: 5px;
        }
    </style>
</head>
<body>

<div class="dashboard">
    <div class="sidebar">
        <h3>Locations</h3>
        <div class="city-item active" onclick="updateWeather('Nagpur')">
            <span>Nagpur</span>
            <span>34°C</span>
        </div>
        <div class="city-item" onclick="updateWeather('Mumbai')">
            <span>Mumbai</span>
            <span>31°C</span>
        </div>
        <div class="city-item" onclick="updateWeather('Delhi')">
            <span>Delhi</span>
            <span>37°C</span>
        </div>
        <div class="city-item" onclick="updateWeather('Bangalore')">
            <span>Bangalore</span>
            <span>28°C</span>
        </div>
        <div class="city-item" onclick="updateWeather('Pune')">
            <span>Pune</span>
            <span>32°C</span>
        </div>
    </div>

    <div class="main-display">
        <div>
            <h1 id="city-title">Nagpur</h1>
            <p id="state-sub">Maharashtra, India</p>
            <div class="temp-box">
                <h2 id="main-temp">34</h2>
                <span class="deg-symbol">°C</span>
            </div>
            <p id="condition-text" style="letter-spacing: 3px; text-transform: uppercase;">Sunny</p>
        </div>

        <div class="stats-row">
            <div class="stat-card">
                <label>Humidity</label>
                <strong id="hum-val">25%</strong>
            </div>
            <div class="stat-card">
                <label>Wind Speed</label>
                <strong id="wind-val">5 km/h</strong>
            </div>
            <div class="stat-card">
                <label>Visibility</label>
                <strong id="vis-val">10 km</strong>
            </div>
        </div>
    </div>
</div>

<script>
    // Static data object for the cities
    const weatherData = {
        'Nagpur': { state: 'Maharashtra, India', temp: 34, cond: 'Sunny', hum: '25%', wind: '5 km/h', vis: '10 km' },
        'Mumbai': { state: 'Maharashtra, India', temp: 31, cond: 'Humid', hum: '78%', wind: '12 km/h', vis: '8 km' },
        'Delhi': { state: 'National Capital Territory', temp: 37, cond: 'Hazy', hum: '15%', wind: '8 km/h', vis: '4 km' },
        'Bangalore': { state: 'Karnataka, India', temp: 28, cond: 'Cloudy', hum: '50%', wind: '15 km/h', vis: '12 km' },
        'Pune': { state: 'Maharashtra, India', temp: 32, cond: 'Clear Sky', hum: '40%', wind: '10 km/h', vis: '10 km' }
    };

    function updateWeather(city) {
        // 1. Update text content
        const data = weatherData[city];
        document.getElementById('city-title').innerText = city;
        document.getElementById('state-sub').innerText = data.state;
        document.getElementById('main-temp').innerText = data.temp;
        document.getElementById('condition-text').innerText = data.cond;
        document.getElementById('hum-val').innerText = data.hum;
        document.getElementById('wind-val').innerText = data.wind;
        document.getElementById('vis-val').innerText = data.vis;

        // 2. Manage active class in sidebar
        const items = document.querySelectorAll('.city-item');
        items.forEach(item => {
            item.classList.remove('active');
            if(item.querySelector('span').innerText === city) {
                item.classList.add('active');
            }
        });
    }
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Travel Blog</title>
<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background-color: #f0f4f8;
  color: #333;
}

header {
  background: linear-gradient(90deg, #4facfe, #00f2fe);
  color: white;
  padding: 25px 20px;
  text-align: center;
  font-size: 32px;
  font-weight: bold;
  box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

nav {
  display: flex;
  justify-content: center;
  margin-top: 10px;
  gap: 30px;
  flex-wrap: wrap;
}

nav a {
  color: white;
  text-decoration: none;
  font-weight: 600;
  position: relative;
  padding-bottom: 3px;
  transition: color 0.3s;
}

nav a::after {
  content: '';
  position: absolute;
  width: 0%;
  height: 2px;
  background: #ffd700;
  left: 0;
  bottom: 0;
  transition: width 0.3s;
}

nav a:hover::after {
  width: 100%;
}

nav a:hover {
  color: #ffd700;
}

.container {
  max-width: 1300px;
  margin: 40px auto;
  padding: 0 20px;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 30px;
}

.blog-card {
  position: relative;
  background: white;
  border-radius: 15px;
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.3s, box-shadow 0.3s;
}

.blog-card:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 0 15px 35px rgba(0,0,0,0.25);
}

.blog-image {
  width: 100%;
  height: 220px;
  object-fit: cover;
  transition: transform 0.3s;
}

.blog-card:hover .blog-image {
  transform: scale(1.05);
}

.blog-content {
  padding: 15px;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.blog-content h3 {
  margin: 0 0 10px 0;
  color: #333;
  font-size: 20px;
}

.blog-content p {
  margin: 0 0 10px 0;
  color: #555;
  font-size: 15px;
}

.blog-tags {
  margin-bottom: 10px;
}

.blog-tags span {
  background: #4facfe;
  color: white;
  padding: 4px 8px;
  border-radius: 5px;
  font-size: 12px;
  margin-right: 5px;
}

.read-more {
  background: linear-gradient(90deg, #4facfe, #00f2fe);
  color: white;
  border: none;
  padding: 10px 15px;
  border-radius: 8px;
  cursor: pointer;
  width: fit-content;
  transition: background 0.3s;
  text-decoration: none;
  text-align: center;
  align-self: start;
}

.read-more:hover {
  background: linear-gradient(90deg, #0077ff, #00c3ff);
}

footer {
  background-color: #333;
  color: white;
  padding: 25px 20px;
  text-align: center;
  font-size: 14px;
}

footer a {
  color: #4facfe;
  margin: 0 10px;
  text-decoration: none;
}

footer a:hover {
  color: #00f2fe;
}

@media (max-width: 600px) {
  .blog-image {
    height: 180px;
  }
}
</style>
</head>

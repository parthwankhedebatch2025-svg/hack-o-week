<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>Creative Image Gallery</title>

<style>

body{
margin:0;
font-family:'Segoe UI', sans-serif;
background:royalblue;
color:white;
text-align:center;
}

h1{
padding:25px;
font-size:40px;
letter-spacing:2px;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
padding:40px;
max-width:1300px;
margin:auto;
}

.gallery img{
width:100%;
border-radius:15px;
cursor:pointer;
transition:0.4s;
box-shadow:0 8px 20px rgba(0,0,0,0.25);
}

.gallery img:hover{
transform:scale(1.08);
box-shadow:0 15px 35px rgba(0,0,0,0.5);
}

#lightbox{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.9);
display:none;
align-items:center;
justify-content:center;
flex-direction:column;
}

#lightbox img{
max-width:80%;
max-height:70%;
border-radius:12px;
box-shadow:0 20px 40px rgba(0,0,0,0.8);
animation:zoom 0.4s;
}

@keyframes zoom{
from{transform:scale(0.7)}
to{transform:scale(1)}
}

.close{
position:absolute;
top:20px;
right:40px;
font-size:45px;
color:white;
cursor:pointer;
}

.prev,.next{
position:absolute;
top:50%;
font-size:60px;
color:white;
cursor:pointer;
padding:20px;
user-select:none;
}

.prev{ left:40px; }
.next{ right:40px; }

.prev:hover,.next:hover{
color:#ddd;
}

.caption{
margin-top:15px;
font-size:20px;
color:white;
}

footer{
padding:20px;
opacity:0.8;
}

</style>

</head>

<body>

<h1>✨ My Creative Image Gallery ✨</h1>

<div class="gallery">

<img src="https://picsum.photos/id/1015/500/350" onclick="openLightbox(0)">
<img src="https://picsum.photos/id/1016/500/350" onclick="openLightbox(1)">
<img src="https://picsum.photos/id/1018/500/350" onclick="openLightbox(2)">
<img src="https://picsum.photos/id/1020/500/350" onclick="openLightbox(3)">
<img src="https://picsum.photos/id/1024/500/350" onclick="openLightbox(4)">
<img src="https://picsum.photos/id/1035/500/350" onclick="openLightbox(5)">
<img src="https://picsum.photos/id/1043/500/350" onclick="openLightbox(6)">
<img src="https://picsum.photos/id/1050/500/350" onclick="openLightbox(7)">
<img src="https://picsum.photos/id/1069/500/350" onclick="openLightbox(8)">
<img src="https://picsum.photos/id/1074/500/350" onclick="openLightbox(9)">
<img src="https://picsum.photos/id/1084/500/350" onclick="openLightbox(10)">
<img src="https://picsum.photos/id/1080/500/350" onclick="openLightbox(11)">

</div>

<div id="lightbox">

<span class="close" onclick="closeLightbox()">×</span>

<span class="prev" onclick="changeImage(-1)">❮</span>

<img id="lightbox-img">

<div class="caption" id="caption"></div>

<span class="next" onclick="changeImage(1)">❯</span>

</div>

<footer>
Image Gallery Demo
</footer>

<script>

let images = [
"https://picsum.photos/id/1015/900/600",
"https://picsum.photos/id/1016/900/600",
"https://picsum.photos/id/1018/900/600",
"https://picsum.photos/id/1020/900/600",
"https://picsum.photos/id/1024/900/600",
"https://picsum.photos/id/1035/900/600",
"https://picsum.photos/id/1043/900/600",
"https://picsum.photos/id/1050/900/600",
"https://picsum.photos/id/1069/900/600",
"https://picsum.photos/id/1074/900/600",
"https://picsum.photos/id/1084/900/600",
"https://picsum.photos/id/1080/900/600"
];

let captions = [
"Beautiful Mountain",
"Forest Path",
"Peaceful Lake",
"Golden Sunset",
"Wildlife Moment",
"Nature Landscape",
"Snowy Mountain",
"Ocean Waves",
"Green Valley",
"Quiet Village",
"Wild River",
"Evening Sky"
];

let currentIndex = 0;

function openLightbox(index){
currentIndex = index;
document.getElementById("lightbox").style.display="flex";
document.getElementById("lightbox-img").src = images[currentIndex];
document.getElementById("caption").innerText = captions[currentIndex];
}

function closeLightbox(){
document.getElementById("lightbox").style.display="none";
}

function changeImage(step){
currentIndex += step;

if(currentIndex < 0){
currentIndex = images.length-1;
}

if(currentIndex >= images.length){
currentIndex = 0;
}

document.getElementById("lightbox-img").src = images[currentIndex];
document.getElementById("caption").innerText = captions[currentIndex];
}

document.addEventListener("keydown",function(e){

if(e.key === "ArrowRight"){
changeImage(1);
}

if(e.key === "ArrowLeft"){
changeImage(-1);
}

if(e.key === "Escape"){
closeLightbox();
}

});

</script>

</body>
</html>

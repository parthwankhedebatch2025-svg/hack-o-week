<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Portfolio</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(to right, #e3f2fd, #fce4ec);
            color: #333;
        }

        header {
            background: linear-gradient(to right, #1e3c72, #2a5298);
            color: white;
            text-align: center;
            padding: 60px 20px;
        }

        header img {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            border: 5px solid white;
            margin-bottom: 20px;
        }

        header h1 {
            margin: 10px 0;
            font-size: 40px;
        }

        header p {
            font-size: 18px;
            opacity: 0.9;
        }

        section {
            max-width: 1000px;
            margin: 50px auto;
            background-color: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

        section h2 {
            text-align: center;
            font-size: 32px;
            color: #2a5298;
            margin-bottom: 20px;
        }

        section p {
            font-size: 18px;
            line-height: 1.8;
            text-align: center;
        }

        /* Skills Section */
        .skills {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 25px;
            margin-top: 30px;
        }

        .skill-box {
            background: linear-gradient(to right, #2a5298, #1e3c72);
            color: white;
            padding: 25px 40px;
            font-size: 22px;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        .skill-box:hover {
            transform: translateY(-8px) scale(1.05);
            background: linear-gradient(to right, #ff512f, #dd2476);
        }

        /* Projects */
        .projects {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .project-card {
            background-color: #f5f5f5;
            padding: 25px;
            border-radius: 12px;
            text-align: center;
            transition: transform 0.3s ease;
        }

        .project-card:hover {
            transform: translateY(-6px);
        }

        /* Contact */
        .contact {
            text-align: center;
        }

        .contact button {
            background: linear-gradient(to right, #ff512f, #dd2476);
            color: white;
            border: none;
            padding: 18px 40px;
            font-size: 20px;
            border-radius: 50px;
            cursor: pointer;
            margin-top: 20px;
            transition: transform 0.3s ease;
        }

        .contact button:hover {
            transform: scale(1.1);
        }

        footer {
            background-color: #1e3c72;
            color: white;
            text-align: center;
            padding: 25px;
            font-size: 16px;
        }
    </style>
</head>

<body>

    <header>
        <img src="https://C:\Users\sit.lab7\Desktop\Myportfolio\pfp.jpg" alt="Profile Photo">
        <h1>Your Name</h1>
        <p>Aspiring Web Developer | Creative Learner</p>
    </header>

    <section>
        <h2>About Me</h2>
        <p>
            Hello! 👋 I am <strong>Parth Wankhede</strong>, an aspiring web developer
            who loves creating visually appealing and user-friendly websites.
            I enjoy learning new technologies and building projects that help
            me grow as a developer.
        </p>
        <p>
            My goal is to become a skilled full-stack developer and work on
            meaningful projects that make a difference.
        </p>
    </section>

    <section>
        <h2>My Skills</h2>
        <div class="skills">
            <div class="skill-box">HTML</div>
            <div class="skill-box">CSS</div>
            <div class="skill-box">JavaScript</div>
            <div class="skill-box">Responsive Design</div>
            <div class="skill-box">Creativity</div>
        </div>
    </section>

    <section>
        <h2>Projects</h2>
        <div class="projects">
            <div class="project-card">
                <h3>Personal Portfolio</h3>
                <p>A responsive personal portfolio website using HTML & CSS.</p>
            </div>

            <div class="project-card">
                <h3>Landing Page</h3>
                <p>A modern landing page with animations and gradients.</p>
            </div>

            <div class="project-card">
                <h3>Basic Calculator</h3>
                <p>A simple calculator built using HTML, CSS, and JavaScript.</p>
            </div>
        </div>
    </section>

    <section class="contact">
        <h2>Contact Me</h2>
        <p>Interested in working together or learning more?</p>
        <button>Email Me</button>
    </section>

    <footer>
        <p>© 2026 Your Name | Designed with ❤️</p>
    </footer>

</body>
</html>

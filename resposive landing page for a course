<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pro Course Landing Page</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
:root {
  --primary: #6c63ff;
  --secondary: #00c9a7;
  --dark: #1e1e2f;
  --light: #f5f7ff;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Poppins', sans-serif;
}

body {
  background: var(--light);
  color: var(--dark);
}

/* Navbar */
nav {
  position: sticky;
  top: 0;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: space-between;
  padding: 15px 10%;
  z-index: 1000;
}

nav h2 {
  color: var(--primary);
}

nav a {
  text-decoration: none;
  margin-left: 20px;
  color: var(--dark);
  font-weight: 500;
}

/* Hero */
.hero {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  padding: 80px 10%;
  background: linear-gradient(135deg, #6c63ff, #00c9a7);
  color: white;
}

.hero-text {
  flex: 1;
}

.hero-text h1 {
  font-size: 48px;
  margin-bottom: 20px;
}

.hero-text p {
  margin-bottom: 20px;
}

.hero-text button {
  padding: 12px 30px;
  border: none;
  background: white;
  color: var(--primary);
  border-radius: 30px;
  cursor: pointer;
  transition: 0.3s;
}

.hero-text button:hover {
  transform: scale(1.05);
}

.hero img {
  flex: 1;
  max-width: 100%;
}

/* Stats */
.stats {
  display: flex;
  justify-content: space-around;
  padding: 40px 10%;
  background: white;
}

.stat h3 {
  color: var(--primary);
}

/* Features */
.features {
  padding: 80px 10%;
  text-align: center;
}

.feature-box {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  margin-top: 40px;
}

.feature {
  flex: 1 1 250px;
  padding: 25px;
  background: white;
  border-radius: 15px;
  transition: 0.3s;
}

.feature:hover {
  transform: translateY(-10px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

/* Pricing */
.pricing {
  padding: 80px 10%;
  background: #f0f3ff;
  text-align: center;
}

.price-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  margin-top: 40px;
}

.card {
  flex: 1 1 250px;
  background: white;
  padding: 30px;
  border-radius: 15px;
  transition: 0.3s;
}

.card:hover {
  transform: scale(1.05);
}

.card h3 {
  margin-bottom: 10px;
}

.card button {
  margin-top: 15px;
  padding: 10px 20px;
  border: none;
  background: var(--primary);
  color: white;
  border-radius: 20px;
  cursor: pointer;
}

/* FAQ */
.faq {
  padding: 80px 10%;
}

.faq-item {
  margin-bottom: 20px;
}

.faq-item h4 {
  cursor: pointer;
  background: var(--primary);
  color: white;
  padding: 10px;
  border-radius: 5px;
}

.faq-item p {
  display: none;
  padding: 10px;
  background: white;
}

/* CTA */
.cta {
  padding: 80px 10%;
  text-align: center;
  background: linear-gradient(135deg, #00c9a7, #6c63ff);
  color: white;
}

.cta button {
  margin-top: 20px;
  padding: 12px 30px;
  border: none;
  background: white;
  color: var(--primary);
  border-radius: 30px;
}

/* Footer */
footer {
  text-align: center;
  padding: 20px;
  background: var(--dark);
  color: white;
}

/* Responsive */
@media(max-width:768px){
  .hero {
    flex-direction: column;
  }

  .stats {
    flex-direction: column;
    gap: 20px;
    text-align: center;
  }
}
</style>
</head>

<body>

<nav>
  <h2>ProCourse</h2>
  <div>
    <a href="#">Home</a>
    <a href="#">Features</a>
    <a href="#">Pricing</a>
    <a href="#">FAQ</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-text">
    <h1>Master Web Development</h1>
    <p>Become a full-stack developer with hands-on projects.</p>
    <button>Get Started</button>
  </div>
  <img src="https://via.placeholder.com/500">
</section>

<section class="stats">
  <div class="stat"><h3>10K+</h3><p>Students</p></div>
  <div class="stat"><h3>4.8⭐</h3><p>Rating</p></div>
  <div class="stat"><h3>50+</h3><p>Lessons</p></div>
</section>

<section class="features">
  <h2>Course Features</h2>
  <div class="feature-box">
    <div class="feature"><h3>Live Projects</h3><p>Build real apps.</p></div>
    <div class="feature"><h3>Mentorship</h3><p>Get expert guidance.</p></div>
    <div class="feature"><h3>Certification</h3><p>Earn a certificate.</p></div>
  </div>
</section>

<section class="pricing">
  <h2>Pricing</h2>
  <div class="price-cards">
    <div class="card">
      <h3>Basic</h3>
      <p>₹999</p>
      <button>Buy Now</button>
    </div>
    <div class="card">
      <h3>Pro</h3>
      <p>₹1999</p>
      <button>Buy Now</button>
    </div>
  </div>
</section>

<section class="faq">
  <h2>FAQ</h2>
  <div class="faq-item">
    <h4 onclick="toggleFAQ(this)">Is it beginner friendly?</h4>
    <p>Yes, absolutely!</p>
  </div>
  <div class="faq-item">
    <h4 onclick="toggleFAQ(this)">Do I get certificate?</h4>
    <p>Yes, after completion.</p>
  </div>
</section>

<section class="cta">
  <h2>Start Your Journey Today</h2>
  <button>Enroll Now</button>
</section>

<footer>
  <p>© 2026 ProCourse</p>
</footer>

<script>
function toggleFAQ(element) {
  let p = element.nextElementSibling;
  p.style.display = p.style.display === "block" ? "none" : "block";
}
</script>

</body>
</html>
